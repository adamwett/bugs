{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"root": true,
	"files": {
		"includes": ["**/*.ts"]
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 120
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"jsxQuoteStyle": "single",
			"semicolons": "always",
			"arrowParentheses": "always"
		}
	}
}
